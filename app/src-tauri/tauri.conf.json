{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "VITE_DESKTOP_BACKEND_ENDPOINT=https://prism.qunqin.org pnpm build",
    "beforeDevCommand": "VITE_DESKTOP_BACKEND_ENDPOINT=https://prism.qunqin.org pnpm exec vite --host localhost --port 1420 --strictPort",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "",
    "targets": "all",
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "longDescription": "",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": {
          "width": 760,
          "height": 440
        },
        "appPosition": {
          "x": 190,
          "y": 230
        },
        "applicationFolderPosition": {
          "x": 570,
          "y": 230
        }
      }
    },
    "resources": [],
    "shortDescription": "",
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "productName": "Prism",
  "mainBinaryName": "Prism",
  "version": "0.1.2",
  "identifier": "org.qunqin.prism",
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "Prism",
        "width": 1000,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  }
}
